{
  "agentPushNotifEnabled": true,
  "awaySummaryEnabled": false,
  "editorMode": "normal",
  "effortLevel": "high",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "open -g 'raycast://confetti?emojis=🔔'",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|idle_prompt"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/progfay/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "open -g 'raycast://confetti?emojis=✅'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "inputNeededNotifEnabled": true,
  "language": "Japanese",
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(npm show:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git grep *)",
      "Bash(gh pr list *)",
      "Bash(gh api:*)",
      "Bash(jq:*)",
      "Bash(fx:*)"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(gh api * --method POST *)"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(redis-cli:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(nc:*)",
      "Bash(telnet:*)",
      "Bash(aws:*)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(yarn *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",
      "Read(*token*)",
      "Read(*secret*)",
      "Read(*password*)",
      "Read(.aws/*)",
      "Read(.ssh/*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Edit(.aws/*)",
      "Edit(.ssh/*)"
    ]
  },
  "theme": "auto",
  "tui": "fullscreen",
  "useAutoModeDuringPlan": true
}